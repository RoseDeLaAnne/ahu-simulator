# Public DNS name that points to this server
MOBILE_PUBLIC_HOST=api.ahu-simulator.example

# Email for ACME/Let's Encrypt certificate notifications
MOBILE_TLS_EMAIL=ops@ahu-simulator.example

# Comma-separated list of mobile app origins allowed by CORS
MOBILE_CORS_ORIGINS=https://app.ahu-simulator.example,https://mobile.ahu-simulator.example

# Comma-separated list of trusted Host headers accepted by FastAPI
MOBILE_TRUSTED_HOSTS=api.ahu-simulator.example
