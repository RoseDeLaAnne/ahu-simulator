# Public HTTPS endpoint used by Android shell.
# Replace with a real reachable host before build (placeholder domains are rejected).
MOBILE_BACKEND_HTTPS_URL=https://api.ahu-simulator.example/dashboard

# Capacitor identity
MOBILE_APP_ID=com.ahusimulator.mobile
MOBILE_APP_NAME=AHU Simulator

# Release artifact type: AAB or APK
MOBILE_ANDROID_RELEASE_TYPE=AAB

# Optional signing settings for release builds
# MOBILE_ANDROID_KEYSTORE_PATH=C:/secrets/ahu-release.jks
# MOBILE_ANDROID_KEYSTORE_PASSWORD=change-me
# MOBILE_ANDROID_KEY_ALIAS=ahu-release
# MOBILE_ANDROID_KEY_ALIAS_PASSWORD=change-me
