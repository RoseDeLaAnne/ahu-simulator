      "max_opacity": 0.92,
      "pulse_speed": 1.7
    },
    "damper_position": {
      "target_nodes": [
        "pvu.damper.intake",
        "pvu.damper.living",
        "pvu.damper.bedroom_north",
        "pvu.damper.bedroom_south",
        "pvu.damper.study",
        "pvu.damper.kitchen"
      ],
      "axis": "Z",
      "closed_angle_deg": -58,
      "open_angle_deg": 8,
      "driver_signal": "flows.flow_fan_to_room.intensity",
      "response": 3.2
    },
    "plume_pulse": {
      "target_nodes": [
        "pvu.flow.room_plumes"
      ],
      "axis": "Y",
      "min_scale": 0.88,
      "max_scale": 1.22,
      "min_opacity": 0.12,
      "max_opacity": 0.48,
      "pulse_speed": 1.15,
      "driver_signal": "flows.flow_fan_to_room.intensity"
    },
    "sensor_pulse": {
      "target_nodes": [
        "pvu.sensors.outdoor_temp",
        "pvu.sensors.filter_pressure",
        "pvu.sensors.supply_temp",
        "pvu.sensors.airflow",
        "building.sensors.room_temp"
      ],
      "min_scale": 0.94,
      "max_scale": 1.14,
      "pulse_speed": 1.6,
      "emissive_strength": 1.05
    }
  },
  "status_colors": {
    "normal": "#22c55e",
    "warning": "#facc15",
    "alarm": "#ef4444",
    "inactive": "#64748b"
  },
  "emissive_highlight": {
    "hover": "#334155",
    "selected": "#475569",
