# Copy to config/local.env for local overrides.
# Real environment variables override values from config/local.env.

AHU_SIMULATOR_DEVELOPER_TOOLS_ENABLED=false

# AHU_SIMULATOR_PORT=8000
# AHU_SIMULATOR_SETTINGS_FILE=config/defaults.yaml
# AHU_SIMULATOR_DASHBOARD_PATH=/dashboard
# AHU_SIMULATOR_DEFAULT_SCENARIO_ID=midseason

AHU_SIMULATOR_CORS_ALLOW_ORIGINS=http://127.0.0.1,http://localhost,http://127.0.0.1:8000,http://localhost:8000
AHU_SIMULATOR_CORS_ALLOW_METHODS=GET,POST,OPTIONS
AHU_SIMULATOR_CORS_ALLOW_HEADERS=*
AHU_SIMULATOR_CORS_ALLOW_CREDENTIALS=true
AHU_SIMULATOR_TRUSTED_HOSTS=*
AHU_SIMULATOR_ENFORCE_HTTPS_REDIRECT=false
